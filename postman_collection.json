{"info": 
{"name": "ArtisanConnect API v1.6",
"description": "Collection complète pour tester l'API ArtisanConnect - Backend 1 Sprint", 
"version": "1.6.0",
 "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"}, 
 "variable": [
    {"key": "base_url", 
    "value": "http://127.0.0.1:8000/api", 
    "type": "string"}, 
    {"key": "token", 
    "value": "", 
    "type": "string"}], 
    "item": [
        {"name": "Authentification", 
        "item": [
            {"name": "Register", 
            "request": {
            "method": "POST",
            "header": [
            {"key": "Content-Type", 
            "value": "application/json"}], 
            "body": {"mode": "raw", "raw": "{\n  \"nom\": \"Test\",\n  \"prenom\": \"User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"telephone\": \"770000000\",\n  \"role\": \"acheteur\",\n  \"date_naissance\": \"1990-01-01\"\n}"},
             "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]}}},
              {"name": "Login", "request": {"method": "POST", "header": [
                {"key": "Content-Type", "value": "application/json"}], 
                "body": {"mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"}, 
                "url": {"raw": "{{base_url}}/auth/login", 
                "host": ["{{base_url}}"], "path": ["auth", "login"]}}, 
                "event": [{"listen": "test", 
                "script": {"exec": ["if (pm.response.code === 200) {", "    const response = pm.response.json();", "    pm.collectionVariables.set('token', response.data.token);", "}"]}}]},     {"name": "Profile", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": {"raw": "{{base_url}}/auth/profile", "host": ["{{base_url}}"], "path": ["auth", "profile"]}}}]}, {"name": "Catalogue Public", 
     "item": [{"name": "Categories", "request": {"method": "GET", 
     "url": {"raw": "{{base_url}}/catalog/categories", "host": ["{{base_url}}"],
     "path": ["catalog", "categories"]}}}, 
     {"name": "Oeuvres", 
     "request": {"method": "GET", 
     "url": {"raw": "{{base_url}}/catalog/oeuvres?page=1&per_page=15&sort_by=recent", 
     "host": ["{{base_url}}"], "path": ["catalog", "oeuvres"], 
     "query": [{"key": "page", "value": "1"}, 
     {"key": "per_page", "value": "15"}, 
     {"key": "sort_by", "value": "recent"}]}}},
      {"name": "Oeuvre Detail", "request": {"method": "GET",
       "url": {"raw": "{{base_url}}/catalog/oeuvres/1", 
       "host": ["{{base_url}}"], "path": ["catalog", "oeuvres", "1"]}}}, 
       {"name": "Stats", "request": {"method": "GET", "url": {"raw": "{{base_url}}/catalog/stats",
        "host": ["{{base_url}}"], "path": ["catalog", "stats"]}}}]}, 
        {"name": "Acheteur", "item": [{"name": "Panier - Ajouter", 
        "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}],
         "body": {"mode": "raw", "raw": "{\n  \"oeuvre_id\": 1,\n  \"quantite\": 1\n}"}, 
         "url": {"raw": "{{base_url}}/acheteur/panier/ajouter", "host": ["{{base_url}}"], 
         "path": ["acheteur", "panier", "ajouter"]}}}, {"name": "Panier - Voir", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
          "url": {"raw": "{{base_url}}/acheteur/panier", "host": ["{{base_url}}"], 
          "path": ["acheteur", "panier"]}}}, {"name": "Commande - Créer",
           "request": {"method": "POST", "header": [{"key": "Authorization", 
           "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], 
           "body": {"mode": "raw", "raw": "{\n  \"adresse_livraison\": \"123 Rue Test, Abidjan\",\n  \"telephone_livraison\": \"770000000\",\n  \"instructions_livraison\": \"Porte bleue\",\n  \"methode_paiement\": \"orange_money\"\n}"},
            "url": {"raw": "{{base_url}}/acheteur/commandes", "host": ["{{base_url}}"], 
            "path": ["acheteur", "commandes"]}}}, {"name": "Paiement - Initier", 
            "request": {"method": "POST", "header": [{"key": "Authorization",
            
            "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], 
            "body": {"mode": "raw", "raw": "{\n  \"commande_id\": 1,\n  \"methode\": \"orange_money\",\n  \"telephone\": \"770000000\"\n}"}, 
            "url": {"raw": "{{base_url}}/acheteur/paiement/initier", "host": ["{{base_url}}"], 
            "path": ["acheteur", "paiement", "initier"]}}}, {"name": "Avis - Créer", 
            "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, 
            {"key": "Content-Type", "value": "application/json"}], 
            "body": {"mode": "raw", "raw": "{\n  \"oeuvre_id\": 1,\n  \"note\": 5,\n  \"titre_avis\": \"Excellent travail\",\n  \"commentaire\": \"Très belle œuvre, je recommande\"\n}"}, 
            "url": {"raw": "{{base_url}}/acheteur/avis", "host": ["{{base_url}}"], "path": ["acheteur", "avis"]}}},
             {"name": "Favoris - Ajouter", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, 
             {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"oeuvre_id\": 1\n}"}, "url": {"raw": "{{base_url}}/acheteur/favoris", "host": ["{{base_url}}"], "path": ["acheteur", "favoris"]}}},
             
             {"name": "Notifications", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], 
             "url": {"raw": "{{base_url}}/acheteur/notifications", "host": ["{{base_url}}"], 
             "path": ["acheteur", "notifications"]}}}]},
              {"name": "Artisan", "item": [{"name": "Dashboard", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], 
              "url": {"raw": "{{base_url}}/artisan/dashboard", "host": ["{{base_url}}"], 
              "path": ["artisan", "dashboard"]}}}, 
              {"name": "Mes Oeuvres", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], 
              "url": {"raw": "{{base_url}}/artisan/oeuvres", "host": ["{{base_url}}"], 
              "path": ["artisan", "oeuvres"]}}}, 
              {"name": "Créer Oeuvre", 
              "request": {"method": "POST", "header":
               [{"key": "Authorization", "value": "Bearer {{token}}"}, 
               {"key": "Content-Type", "value": "application/json"}], 
               "body": {"mode": "raw", "raw": "{\n  \"categorie_id\": 1,\n  \"titre\": \"Test Œuvre\",\n  \"description\": \"Description de test\",\n  \"prix\": 5000,\n  \"quantite_disponible\": 1,\n  \"dimensions\": {\n    \"longueur\": 10,\n    \"largeur\": 10,\n    \"hauteur\": 5\n  },\n  \"materiaux\": [\"Bois\", \"Peinture\"]\n}"}, "url": {"raw": "{{base_url}}/artisan/oeuvres", 
              "host": ["{{base_url}}"], "path": ["artisan", "oeuvres"]}}}]}, {"name": "Admin", "item": [{"name": "Dashboard", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": {"raw": "{{base_url}}/admin/dashboard", "host": ["{{base_url}}"], "path": ["admin", "dashboard"]}}}, 
              {"name": "Oeuvres en attente", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": {"raw": "{{base_url}}/admin/oeuvres/en-attente", "host": ["{{base_url}}"], "path": ["admin", "oeuvres", "en-attente"]}}},
               {"name": "Valider Oeuvre", "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"notes_validation\": \"Œuvre de grande qualité\"\n}"}, "url": {"raw": "{{base_url}}/admin/oeuvres/1/valider", "host": ["{{base_url}}"],
                "path": ["admin", "oeuvres", "1", "valider"]}}}]}]}

# Configuration Production ArtisanConnect
# Copier ce fichier vers .env.production pour la production

APP_NAME="ArtisanConnect"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.artisanconnect.ci
APP_TIMEZONE=Africa/Abidjan

# Configuration Base de Données
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artisan_connect_prod
DB_USERNAME=artisan_user
DB_PASSWORD=secure_password_here

# Configuration Redis (Cache & Sessions)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configuration Cache
CACHE_DRIVER=redis
CACHE_PREFIX=artisan_connect_prod_

# Configuration Sessions
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.artisanconnect.ci

# Configuration Queue
QUEUE_CONNECTION=redis

# Configuration Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@artisanconnect.ci
MAIL_PASSWORD=mail_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@artisanconnect.ci
MAIL_FROM_NAME="ArtisanConnect"

# Configuration Filesystem (Stockage images)
FILESYSTEM_DISK=public
# Pour le stockage cloud (AWS S3)
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=artisanconnect-images
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Configuration Sanctum (API Authentication)
SANCTUM_STATEFUL_DOMAINS=artisanconnect.ci,www.artisanconnect.ci

# Configuration CORS
CORS_ALLOWED_ORIGINS=https://artisanconnect.ci,https://www.artisanconnect.ci,https://app.artisanconnect.ci

# Configuration Rate Limiting
RATE_LIMITING_ENABLED=true
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTH=500
RATE_LIMIT_PAYMENT=10

# Configuration Logging
LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=daily

# Configuration Monitoring
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# Configuration Performance
OPCACHE_ENABLE=1
OPCACHE_MEMORY_CONSUMPTION=256
OPCACHE_MAX_ACCELERATED_FILES=10000

# Configuration Security
BCRYPT_ROUNDS=12
HASH_DRIVER=bcrypt

# Configuration Upload
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp

# Configuration API
API_VERSION=v1
API_RATE_LIMIT=1000
API_THROTTLE_REQUESTS=1000
API_THROTTLE_MINUTES=1

# Configuration Mobile Money (Production)
ORANGE_MONEY_API_URL=https://api.orange.com/payment
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_SECRET_KEY=

MTN_MONEY_API_URL=https://api.mtn.com/payment
MTN_MONEY_API_KEY=
MTN_MONEY_SECRET_KEY=

MOOV_MONEY_API_URL=https://api.moov.com/payment
MOOV_MONEY_API_KEY=
MOOV_MONEY_SECRET_KEY=

WAVE_API_URL=https://api.wave.com/payment
WAVE_API_KEY=
WAVE_SECRET_KEY=

# Configuration Analytics
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=

# Configuration Social (si applicable)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Configuration Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_DISK=s3

# Configuration SSL
FORCE_HTTPS=true
TRUSTED_PROxies=*

# Configuration Maintenance
MAINTENANCE_DRIVER=file

# Configuration Debug (désactivé en production)
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false
